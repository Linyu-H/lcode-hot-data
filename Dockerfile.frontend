# 前端Dockerfile
FROM node:20-alpine AS builder

WORKDIR /app

# 复制package.json并安装依赖
COPY frontend/package*.json ./
RUN npm install

# 复制源码并构建
COPY frontend/ .
RUN npm run build

# 运行阶段 - 使用nginx提供静态文件
FROM nginx:alpine

# 复制构建好的文件到nginx
COPY --from=builder /app/dist /usr/share/nginx/html

# 复制nginx配置
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
